# agentinsight-researcher 环境变量模板
# 复制为 .env 并填入真实凭据

# ========== 环境与部署 ==========
ENV=dev
ENABLE_TEST_PAGE=true

# ========== LLM 网关 ==========
# FAST_LLM: 意图分类/闲聊响应等轻量任务 (需配置对应 API Key)
FAST_LLM=zhipuai/glm-4-flash
SMART_LLM=deepseek/deepseek-v4-flash
STRATEGIC_LLM=deepseek/deepseek-v4-pro
MAX_TOTAL_TOKENS=128000

# ========== LLM API Key ==========
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# DASHSCOPE_API_KEY=  # 备选方案 B (qwen-max) 时启用

# ========== 图像生成 ==========
# 默认启用报告配图 (与 src/config/settings.py:86 默认值一致)
# 留空 IMAGE_API_KEY 时复用 DEEPSEEK_API_KEY
IMAGE_GENERATION_ENABLED=true
IMAGE_MODEL=deepseek/deepseek-v4-flash
IMAGE_API_KEY=
# SVG 矢量配图 (DeepSeek V4 Flash 经 /chat/completions 生成 SVG 代码)
IMAGE_OUTPUT_FORMAT=svg
IMAGE_SVG_MAX_TOKENS=16384
IMAGE_SVG_TEMPERATURE=0.7

# ========== 向量库 Qdrant ==========
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ========== Embeddings ==========
EMBEDDINGS_BASE_URL=http://embeddings:8088
EMBEDDINGS_API_KEY=

# ========== Rerank ==========
RERANK_ENABLED=false
RERANK_BASE_URL=http://rerank:8089
RERANK_API_KEY=

# ========== PostgreSQL ==========
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agis
POSTGRES_PASSWORD=
POSTGRES_DB=agents

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0
REDIS_AUTH=

# ========== 可观测性 ==========
AGENTINSIGHT_PUBLIC_KEY=
AGENTINSIGHT_SECRET_KEY=
AGENTINSIGHT_HOST=https://agent.goldebridge.com

# ========== 用户身份 ==========
# 无 JWT Token 时按客户端 IP 生成确定性 UserId
SELF_HOST=True
# 每日报告生成限额 (按 IP 限流, 默认 5 次/日, 仅报告成功才计数; 0=不限制)
IP_DAILY_REPORT_LIMIT=5

# ========== 搜索引擎 API Key ==========
# SearXNG 元搜索引擎 (自托管, 替代 DuckDuckGo 直连, 国内可用)
# 代码变量名: searx_url (src/config/settings.py); agent 容器内通过 compose 网络访问
# host 浏览器访问: http://localhost:8099 (端口见 compose 文件 searxng.ports)
SEARX_URL=http://searxng:8099
BOCHA_API_KEY=
METASO_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_KEY=
SERPER_API_KEY=
SEARCHAPI_API_KEY=
GITHUB_TOKEN=
CROSSREF_MAILTO=
PUBMED_EMAIL=
UNPAYWALL_EMAIL=

# ========== 抓取 ==========
# Agent 并发抓取数据的数量 (控制同时抓取多少个 URL, 影响内存/CPU/带宽)
# 代码变量名: max_scraper_workers (src/config/settings.py → deep_research.py / research_conductor.py)
MAX_SCRAPER_WORKERS=15
FIRECRAWL_API_KEY=

# ========== CORS ==========
# 不推荐 * (暴露面过大), 生产推荐具体域名列表
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8066

# ========== RAGAS 评测 (CI 门禁) ==========
# 评估器 LLM (langchain_openai.ChatOpenAI 直连 DeepSeek API, 非 LiteLLM 前缀)
EVAL_LLM_MODEL=deepseek-chat
EVAL_LLM_API_KEY=
EVAL_LLM_API_BASE=https://api.deepseek.com/v1
# 评估器 Embedding (本地 TEI OpenAI 兼容端点, bge-base-zh-v1.5)
EVAL_EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
EVAL_EMBEDDING_API_BASE=http://localhost:8088/v1
EVAL_EMBEDDING_API_KEY=

# ========== JWT 本地解析 (复用 AgentInsightService JWT 规格) ==========
# 密钥仅环境变量注入, 禁止入仓/硬编码
JWT_SIGNING_KEY=
JWT_ISSUER=
JWT_AUDIENCE=
# JWT_ALGORITHM=HS256  # 固定值, 无需配置
# JWT_CLOCK_SKEW=5  # 默认 5s, 无需配置
# JWT_LOCAL_VERIFY=true  # 默认启用, 无需配置