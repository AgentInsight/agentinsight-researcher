# agentinsight-researcher 环境变量模板
# 严格遵循 AGENTS.md 第 11 章安全合规红线: 密钥仅环境变量注入, 禁止入仓/硬编码/日志
# 复制为 .env 并填入真实凭据; 生产环境用 .env.agent + .env.{env} 分层

# ========== 环境与部署 (AGENTS.md 第 12 章) ==========
# dev | prod
ENV=dev
# 前端测试页面, dev=true / prod=false (AGENTS.md 第 14 章)
ENABLE_TEST_PAGE=true
LOG_LEVEL=INFO

# ========== Docker 容器编排配置 (compose 插值, AGENTS.md 第 12 章) ==========
# 镜像版本 (生产联网模式从 Docker Hub 拉取, QA 离线模式从 tarball 加载)
REDIS_VERSION=7
QDRANT_VERSION=v1.18.0
# Text Embeddings Inference 镜像名
TEI_IMAGE=tei-embedding
TEI_TAG=cpu-1.9

# 服务端口 (compose 端口映射插值)
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_LOG_LEVEL=INFO
EMBEDDINGS_PORT=8088
RERANK_PORT=8089
AGENT_PORT=8066

# Embeddings TEI 服务配置 (AGENTS.md 第 7/12 章)
EMBEDDINGS_MODEL_PATH=/data/bge-large-zh-v1.5
EMBEDDINGS_DTYPE=float32
EMBEDDINGS_MAX_BATCH_TOKENS=16384
EMBEDDINGS_MAX_CLIENT_BATCH_SIZE=32
EMBEDDINGS_MAX_CONCURRENT_REQUESTS=512
EMBEDDINGS_AUTO_TRUNCATE=true
# TEI API_KEY 鉴权, 留空则不鉴权; 启用后客户端须携带 Authorization: Bearer <key>
EMBEDDINGS_API_KEY=

# Rerank TEI 服务配置 (AGENTS.md 第 7/12 章)
RERANK_MODEL_PATH=/data/bge-reranker-v2-m3
RERANK_DTYPE=float16
RERANK_MAX_BATCH_TOKENS=16384
RERANK_MAX_CLIENT_BATCH_SIZE=32
RERANK_MAX_CONCURRENT_REQUESTS=512
# TEI API_KEY 鉴权, 留空则不鉴权; 启用后客户端须携带 Authorization: Bearer <key>
RERANK_API_KEY=

# ========== LLM 网关 (LiteLLM, AGENTS.md 第 9 章) ==========
# 三级模型分工 (V2-P0 方案 H, DeepSeek 全栈 + 智谱免费层):
#   FAST      = zhipuai/glm-4-flash         # 智谱免费层, 极致成本 (分类/摘要/MCP选择)
#   SMART     = deepseek/deepseek-v4-flash  # DeepSeek 轻量 (报告生成/章节/策展)
#   STRATEGIC = deepseek/deepseek-v4-pro    # DeepSeek 思考模式 (规划/事实核查)
#
# 单次研究报告成本 ~0.18 元 (方案 B qwen-max 的 1/4), 真正 3 层分离.
# ⚠️ 旧模型名 deepseek-chat / deepseek-reasoner 将于 2026-07-24 停用, 已迁移到 v4 命名.
FAST_LLM=zhipuai/glm-4-flash
SMART_LLM=deepseek/deepseek-v4-flash
STRATEGIC_LLM=deepseek/deepseek-v4-pro
FAST_TOKEN_LIMIT=3000
SMART_TOKEN_LIMIT=6000
STRATEGIC_TOKEN_LIMIT=4000
SUMMARY_TOKEN_LIMIT=700
TEMPERATURE=0.4
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# LiteLLM 主控 (按需启用, 默认直连模型)
# LITELLM_PROXY_BASE_URL=
# LITELLM_PROXY_API_KEY=

# 各模型 API Key (按实际使用填入)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZHIPU_API_KEY=

# ========== 图像生成 (P2-06 报告配图, deepseek-v4-flash) ==========
# 用户明确要求: 用 deepseek-v4-flash (非 gemini). 通过 LiteLLM aimage_generation 调用.
# 注意: deepseek-v4-flash 图像生成能力假设支持, 实际能力以官方文档为准.
# true 时报告生成配图 (默认关闭)
IMAGE_GENERATION_ENABLED=false
# LiteLLM 路由前缀, 复用 DEEPSEEK_API_KEY
IMAGE_MODEL=deepseek/deepseek-v4-flash
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=standard
# 单独 Key (可选, 留空则复用 DEEPSEEK_API_KEY). 注意: docker compose env_file 不支持行内注释, 注释必须独立一行.
IMAGE_API_KEY=

# ========== 向量库 Qdrant (AGENTS.md 第 7/12 章) ==========
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# 单一集合, payload namespace 隔离
QDRANT_COLLECTION=agents
# bge-large-zh-v1.5 固定维度
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine

# ========== Embeddings (AGENTS.md 第 1/7 章, 远程 TEI 服务) ==========
EMBEDDINGS_BASE_URL=http://embeddings:8088
EMBEDDINGS_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDINGS_DIMENSION=1024

# ========== Rerank (AGENTS.md 第 7 章, 远程服务) ==========
# 默认不启用; 启用时需启动 rerank 容器 (docker compose --profile rerank up -d)
# true 时启用 bge-reranker-v2-m3 重排序
RERANK_ENABLED=false
RERANK_BASE_URL=http://rerank:8089
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_K=5

# ========== PostgreSQL (AGENTS.md 第 6/12 章, Checkpointer+业务元数据) ==========
POSTGRES_VERSION=17
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agents
POSTGRES_USER=agentinsight
POSTGRES_PASSWORD=
POSTGRES_CONNECTION_POOL_SIZE=10


# ========== Redis (AGENTS.md 第 1/6 章, 缓存+限流+短期会话) ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=

# ========== 可观测性 AgentInsight SDK (AGENTS.md 第 10 章) ==========
AGENTINSIGHT_PUBLIC_KEY=
AGENTINSIGHT_SECRET_KEY=
AGENTINSIGHT_HOST=https://agentinsight.goldebridge.com
# head-based 采样, 高频 embed 降采样
TRACING_EMBEDDING_SAMPLE_RATE=0.5

# ========== 用户身份解析 (AGENTS.md 第 8 章) ==========
DEFAULT_USER_ID=anonymous
USER_INFO_API_URL=https://agentinsight.goldebridge.com/api/user
USER_INFO_API_TIMEOUT=5
# 自托管模式 (True=自托管, JWT可选; False=云托管, 强制JWT校验)
SELF_HOST=True

# ========== 会话与上下文 (AGENTS.md 第 6 章) ==========
# 单会话上下文上限(约 200K token)
CONTEXT_MAX_CHARS=800000
CONTEXT_COMPRESSED_TARGET=200000
# 30 天
CONTEXT_SESSION_TTL=2592000
DEBOUNCE_SECONDS=1.0
FLUSH_INTERVAL_SECONDS=0.5

# ========== 数据隔离 (AGENTS.md 第 7 章) ==========
# agent_id = agent_name, 全局唯一; 用户私有数据 namespace={agent_id}:{user_id}
# 新版 namespace 拆分 (CHITCHAT_FAST_LLM_OPTIMIZATION_PLAN.md):
#   - 闲聊/短查询种子: {agent_id}-chat (short_query + off_topic 子命名空间)
#   - 共享研究数据: {agent_id}-data (所有用户共享)
#   - 用户私有数据: {agent_id}-data:{user_id} (按用户隔离)
AGENT_NAME=agentinsight-researcher

# ========== RAG 检索 (AGENTS.md 第 7 章) ==========
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3
SCORE_THRESHOLD=0.3
# 倒数排名融合常数, 业界标准
RRF_K=60
BM25_K1=1.5
BM25_B=0.75

# ========== 闲聊响应优化 (CHITCHAT_FAST_LLM_OPTIMIZATION_PLAN.md P0-P2) ==========
# 闲聊响应器: FAST_LLM 实时生成 + Persona + 三段式 + 多模板兜底
# true 时启用 FAST_LLM (glm-4-flash) 生成个性化闲聊回复; false 时用固定话术
CHITCHAT_ENABLED=true
# true 时走 FAST_LLM; false 时直接用多模板兜底 (零 LLM 成本)
CHITCHAT_USE_FAST_LLM=true
CHITCHAT_TEMPERATURE=0.7
CHITCHAT_MAX_TOKENS=200
# 流式是否逐字 yield (true 时有打字机效果)
CHITCHAT_STREAM_CHAR_BY_CHAR=true
# FAST 失败时是否降级到多模板兜底
CHITCHAT_FALLBACK_TO_TEMPLATE=true

# ChatAgent 配置 (原 chat_agent.py 硬编码, P2 收敛到 Settings)
CHAT_TEMPERATURE=0.4
CHAT_MAX_TOKENS=4000
CHAT_HISTORY_LIMIT=10
CHAT_REPORT_TRUNCATE_CHARS=50000
# 简单追问长度阈值 (cascade 路由: <阈值 走 FAST, >=阈值+复杂关键词 走 SMART)
CHAT_SIMPLE_QUERY_THRESHOLD_CHARS=20

# QueryClassifier 阈值 (原硬编码, P2 收敛到 Settings)
QUERY_CLASSIFY_LLM_MAX_TOKENS=64
QUERY_CLASSIFY_LLM_QUERY_TRUNCATE=1000
QUERY_CLASSIFY_SINGLE_WORD_MAX_CHARS=6

# FAST LLM 场景化 max_tokens (原散落硬编码, P2 收敛到 Settings)
FAST_CLASSIFY_MAX_TOKENS=200
FAST_SUMMARIZE_MAX_TOKENS=2000
FAST_JSON_MAX_TOKENS=64
FAST_SUMMARY_MODE_MAX_TOKENS=1000

# ========== 搜索引擎 (用户需求 5, 中文优先) ==========
# 国内搜索(中文资料优先)
# 博查搜索, 国内中文质量高
BOCHA_API_KEY=
# 国外搜索(国外资料)
# Tavily 通用搜索
TAVILY_API_KEY=
MAX_SEARCH_RESULTS_PER_QUERY=5

# ========== 抓取 (GPT Researcher 模式, 用户需求 12) ==========
MAX_SCRAPER_WORKERS=15
SCRAPER_RATE_LIMIT_DELAY=0.0
BROWSE_CHUNK_MAX_LENGTH=8192
# bs | browser | playwright | pdf | arxiv
SCRAPER=bs
# 抓取模式 (方案 E): auto(默认,BS+Playwright降级) / lightweight(仅BS) / playwright(强制)
SCRAPER_MODE=auto
# Playwright chromium 路径 (可选, 系统 chromium 时设置, 如 /usr/bin/chromium)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# ========== Token 优化 (GPT Researcher 模式, 用户需求 10) ==========
# EmbeddingsFilter 相似度阈值
SIMILARITY_THRESHOLD=0.35
# 低于此字符数跳过压缩
COMPRESSION_THRESHOLD=8000
# DeepResearch 上下文词数上限
MAX_CONTEXT_WORDS=25000
# 子查询数
MAX_ITERATIONS=3
# 子主题数
MAX_SUBTOPICS=3
DEEP_RESEARCH_BREADTH=3
DEEP_RESEARCH_DEPTH=2
DEEP_RESEARCH_CONCURRENCY=4
# 是否启用 SourceCurator 来源策展
CURATE_SOURCES=false

# ========== MCP (GPT Researcher 模式, 用户需求 9) ==========
# fast | deep | disabled
MCP_STRATEGY=fast
MCP_AUTO_TOOL_SELECTION=true
# LLM 选工具上限
MCP_MAX_TOOLS=3

# ========== 报告输出 (用户需求 6) ==========
# markdown | html | pdf
DEFAULT_REPORT_FORMAT=markdown
# basic_report | detailed_report | deep_research
DEFAULT_REPORT_TYPE=basic_report
# 报告字数下限
TOTAL_WORDS=1200
# APA | MLA | Chicago
REPORT_FORMAT_STYLE=APA

# ========== 文件上传 (用户需求 8) ==========
UPLOAD_DIR=/tmp/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,md,txt,html,csv,xlsx,pptx

# ========== CORS (AGENTS.md 第 11 章, 禁 *) ==========
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8066
