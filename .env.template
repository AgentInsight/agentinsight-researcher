# agentinsight-researcher 环境变量模板
# 复制为 .env 并填入真实凭据

# ========== 环境与部署 ==========
ENV=dev
ENABLE_TEST_PAGE=true

# ========== LLM 网关 ==========
FAST_LLM=zhipuai/glm-4-flash
SMART_LLM=deepseek/deepseek-v4-flash
STRATEGIC_LLM=deepseek/deepseek-v4-pro
MAX_TOTAL_TOKENS=128000

# ========== LLM API Key ==========
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# DASHSCOPE_API_KEY=  # 备选方案 B (qwen-max) 时启用

# ========== 图像生成 ==========
IMAGE_GENERATION_ENABLED=false
IMAGE_MODEL=deepseek/deepseek-v4-flash
IMAGE_API_KEY=

# ========== 向量库 Qdrant ==========
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ========== Embeddings ==========
EMBEDDINGS_BASE_URL=http://embeddings:8088
EMBEDDINGS_API_KEY=

# ========== Rerank ==========
RERANK_ENABLED=false
RERANK_BASE_URL=http://rerank:8089
RERANK_API_KEY=

# ========== PostgreSQL ==========
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agis
POSTGRES_PASSWORD=
POSTGRES_DB=agents

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0
REDIS_AUTH=

# ========== 可观测性 ==========
AGENTINSIGHT_PUBLIC_KEY=
AGENTINSIGHT_SECRET_KEY=
AGENTINSIGHT_HOST=https://agent.goldebridge.com

# ========== 用户身份 ==========
DEFAULT_USER_ID=anonymous
SELF_HOST=True

# ========== 搜索引擎 API Key ==========
# SearXNG 元搜索引擎 (自托管, 替代 DuckDuckGo 直连, 国内可用)
# host 访问: http://localhost:8080/ ; agent 容器内访问: http://searxng:8080/
SEARXNG_BASE_URL=http://localhost:8080/
BOCHA_API_KEY=
METASO_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
SERPAPI_KEY=
SERPER_API_KEY=
SEARCHAPI_API_KEY=
GITHUB_TOKEN=
CROSSREF_MAILTO=
UNPAYWALL_EMAIL=

# ========== 抓取 ==========
FIRECRAWL_API_KEY=

# ========== CORS ==========
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8066

# ========== RAGAS 评测 (AGENTS.md 第 10 章, CI 门禁) ==========
# 评估器 LLM (langchain_openai.ChatOpenAI 直连 DeepSeek API, 非 LiteLLM 前缀)
EVAL_LLM_MODEL=deepseek-chat
EVAL_LLM_API_KEY=
EVAL_LLM_API_BASE=https://api.deepseek.com/v1
# 评估器 Embedding (本地 TEI OpenAI 兼容端点, bge-large-zh-v1.5)
EVAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EVAL_EMBEDDING_API_BASE=http://localhost:8088/v1
EVAL_EMBEDDING_API_KEY=