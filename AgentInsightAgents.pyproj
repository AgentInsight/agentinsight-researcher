    <Content Include="Dockerfile" />
    <Content Include="Dockerfile.searxng" />
    <Content Include="docker-compose.yml" />
    <Content Include="docker-build.sh" />
  </ItemGroup>
  <!-- 源代码: src/ 全量 Python 文件 + 配置文件 (Jinja2 模板 + YAML 配置) -->
