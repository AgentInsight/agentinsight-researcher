<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" DefaultTargets="Build">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{830ad49b-09ee-4f2d-90e5-d2b50139a3dc}</ProjectGuid>
    <ProjectHome />
    <StartupFile>server.py</StartupFile>
    <SearchPath />
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <ProjectTypeGuids>{888888a0-9f3d-457c-b088-3a5042f75d52}</ProjectTypeGuids>
    <LaunchProvider>Standard Python launcher</LaunchProvider>
    <InterpreterId />
    <TestFramework>Pytest</TestFramework>
    <SuppressEnvironmentCreationPrompt>True</SuppressEnvironmentCreationPrompt>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'" />
  <PropertyGroup Condition="'$(Configuration)' == 'Release'" />
  <PropertyGroup>
    <VisualStudioVersion Condition=" '$(VisualStudioVersion)' == '' ">10.0</VisualStudioVersion>
  </PropertyGroup>
  <!-- 项目根配置文件 -->
  <ItemGroup>
    <Content Include="AGENTS.md" />
    <Content Include="pyproject.toml" />
    <Content Include="requirements.txt" />
    <Content Include="requirements.in" />
    <Content Include="requirements-dev.in" />
    <Content Include="requirements-dev.txt" />
    <Content Include="server.py" />
    <Content Include=".env.template" />
    <Content Include=".gitignore" />
    <Content Include=".dockerignore" />
  </ItemGroup>
  <!-- Docker 编排与构建脚本 (联网模式入仓; QA/离线模式由 .gitignore 排除; SearXNG 镜像构建入仓) -->
  <ItemGroup>
    <Content Include="Dockerfile" />
    <Content Include="Dockerfile.searxng" />
    <Content Include="docker-compose.yml" />
    <Content Include="docker-build.sh" />
  </ItemGroup>
  <!-- 源代码: src/ 全量 Python 文件 (AGENTS.md 第 3 章目录结构) -->
  <ItemGroup>
    <Content Include="src\**\*.py" />
  </ItemGroup>
  <!-- 脚本: 在线构建/数据库初始化/SearXNG 与 uv 离线包预备 (QA/离线脚本由 .gitignore 排除) -->
  <ItemGroup>
    <Content Include="scripts\build-online.ps1" />
    <Content Include="scripts\init.sql" />
    <Content Include="scripts\convert_bge_small_zh_to_onnx.py" />
    <Content Include="scripts\prepare-nodejs-packages.ps1" />
    <Content Include="scripts\prepare-nodejs-packages.sh" />
    <Content Include="scripts\prepare-playwright-chromium.ps1" />
    <Content Include="scripts\prepare-playwright-chromium.sh" />
    <Content Include="scripts\prepare-searxng-packages.ps1" />
    <Content Include="scripts\prepare-searxng-packages.sh" />
    <Content Include="scripts\prepare-uv-packages.ps1" />
    <Content Include="scripts\prepare-uv-packages.sh" />
  </ItemGroup>
  <!-- 前端测试页面 (AGENTS.md 第 14 章) -->
  <ItemGroup>
    <Content Include="static\index.html" />
  </ItemGroup>
  <!-- 测试: 全量 Python 文件 (AGENTS.md 第 13 章测试分层) -->
  <ItemGroup>
    <Content Include="tests\**\*.py" />
  </ItemGroup>
  <!-- 评测: 全量 Python 文件 (AGENTS.md 第 10 章评测门禁) -->
  <ItemGroup>
    <Content Include="evals\**\*.py" />
  </ItemGroup>
  <!-- 文档: 全量 Markdown 文件 (本地存档, .gitignore 排除不入仓) -->
  <ItemGroup>
    <Content Include="docs\**\*.md" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="docs\" />
    <Folder Include="evals\" />
    <Folder Include="evals\agent\" />
    <Folder Include="evals\hallucination_eval\" />
    <Folder Include="evals\rag\" />
    <Folder Include="evals\simple_evals\" />
    <Folder Include="packages\" />
    <Folder Include="scripts\" />
    <Folder Include="src\" />
    <Folder Include="src\agents\" />
    <Folder Include="src\agents\ag2\" />
    <Folder Include="src\agents\researcher\" />
    <Folder Include="src\api\" />
    <Folder Include="src\common\" />
    <Folder Include="src\config\" />
    <Folder Include="src\config\researcher\" />
    <Folder Include="src\config\researcher\prompts\" />
    <Folder Include="src\config\researcher\prompts\chitchat\" />
    <Folder Include="src\config\researcher\replies\" />
    <Folder Include="src\graph\" />
    <Folder Include="src\llm\" />
    <Folder Include="src\memory\" />
    <Folder Include="src\observability\" />
    <Folder Include="src\rag\" />
    <Folder Include="src\skills\" />
    <Folder Include="src\skills\researcher\" />
    <Folder Include="src\skills\researcher\scrapers\" />
    <Folder Include="src\skills\researcher\searchers\" />
    <Folder Include="src\tools\" />
    <Folder Include="static\" />
    <Folder Include="tests\" />
    <Folder Include="tests\api\" />
    <Folder Include="tests\e2e\" />
    <Folder Include="tests\exploratory\" />
    <Folder Include="tests\functional\" />
    <Folder Include="tests\manual\" />
    <Folder Include="tests\performance\" />
    <Folder Include="tests\regression\" />
    <Folder Include="tests\unit\" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>