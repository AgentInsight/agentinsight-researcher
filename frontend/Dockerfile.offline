# frontend/Dockerfile.offline (生产/离线模式)
# 多 Agent 预留, 当前单 Agent (agentinsight-researcher)
# 生产离线模式: npm 依赖从 packages/frontend-wheels/ 离线安装 (禁止联网)
# 镜像 node:20-alpine 从 tarball 加载 (packages/images/node-20-alpine.tar)

# ---- builder 阶段 ----
FROM node:20-alpine AS builder

WORKDIR /app

# 离线安装 npm 依赖 (使用预下载的 node_modules tarball)
# 准备脚本: scripts/prepare-frontend-packages.ps1 (Windows) / .sh (Linux)
# 预下载产物: packages/frontend-wheels/node-modules.tar.gz (含完整 node_modules)
COPY packages/frontend-wheels/node-modules.tar.gz /tmp/node-modules.tar.gz

# 先复制 package.json 和 lockfile (用于 npm ci --offline 校验)
COPY frontend/package.json frontend/package-lock.json* ./

# 解压预下载的 node_modules (离线模式, 不联网)
RUN mkdir -p node_modules && \
    tar -xzf /tmp/node-modules.tar.gz -C node_modules --strip-components=1 && \
    rm /tmp/node-modules.tar.gz

# 复制源代码
COPY frontend/ .

# NEXT_PUBLIC_ 构建参数 (Next.js 构建时内联到客户端 bundle, 运行时修改无效)
# - NEXT_PUBLIC_AUTH_API_BASE: 认证 API 地址 (浏览器直连), 默认 https://agentinsight.goldebridge.com
# - NEXT_PUBLIC_DEPLOYMENT_MODE: Agent API 部署模式 (server|local), 默认 server
#   server: 通过 Nginx 按 agentName 路径分发 (/agent/{agentName}/*)
#   local: 浏览器直连后端端口 (http://localhost:{port}/*, 无 Nginx)
# 本地 Docker 构建时传入: --build-arg NEXT_PUBLIC_DEPLOYMENT_MODE=local
# 不传 ARG 时, 代码 fallback 到默认值 (server + https://agentinsight.goldebridge.com)
ARG NEXT_PUBLIC_AUTH_API_BASE
ARG NEXT_PUBLIC_DEPLOYMENT_MODE
# 离线构建 (NPM_CONFIG_OFFLINE=true 避免 npm 联网检查)
ENV NPM_CONFIG_OFFLINE=true
# 修复 node_modules/.bin 执行权限 (Windows 打包的 tarball 解压后执行位丢失)
RUN chmod -R +x node_modules/.bin && npm run build

# ---- runtime 阶段 ----
FROM node:20-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# standalone 产物已包含最小化 node_modules
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

# standalone 模式下入口为 server.js
CMD ["node", "server.js"]
