# ========== Agent API 路由 (双模式, 由 NEXT_PUBLIC_DEPLOYMENT_MODE 控制) ==========
# server (默认): 通过 Nginx 按 agentName 路径分发, 前端请求 /agent/{agentName}/*
# local: 本地开发无 Nginx, 浏览器直连 http://localhost:{port} (端口见 agents.config.ts localPort)
NEXT_PUBLIC_DEPLOYMENT_MODE=local

# ========== SELF_HOST 模式 (运行时变量, 非 NEXT_PUBLIC_ 前缀, 不被构建时内联) ==========
# true: 跳过登录/注册, 直接进聊天页
# false: 显示登录/注册页
# 由 .env / .env.qa 提供, compose env_file 注入容器
SELF_HOST=true

# ========== 认证 API (SELF_HOST=false 时使用, 客户端直连) ==========
# 前端浏览器直接 fetch 此地址 (跨域, 需后端配置 CORS 允许前端域名)
# 本地和服务器都直连此地址, 不区分环境
# NEXT_PUBLIC_ 前缀: 暴露到客户端 bundle (构建时内联)
NEXT_PUBLIC_AUTH_API_BASE=https://agentinsight.goldebridge.com

# ========== 前端端口 ==========
PORT=8801
