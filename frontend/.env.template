# ========== 多 Agent API 地址 (当前 1 个, 预留扩展) ==========
# 注意: 使用 NEXT_PUBLIC_ 前缀, 客户端组件可读取
# Docker 内部地址 (agent-researcher:8066) 仅用于服务端代理;
# 客户端浏览器需要访问宿主机映射端口 (localhost:8066)
NEXT_PUBLIC_AGENT_RESEARCHER_API_URL=http://localhost:8066
# 未来扩展 (取消注释即启用):
# NEXT_PUBLIC_AGENT_WRITER_API_URL=http://localhost:8067
# NEXT_PUBLIC_AGENT_ANALYST_API_URL=http://localhost:8068

# ========== SELF_HOST 模式 ==========
# true: 跳过登录/注册, 直接进聊天页
# false: 显示登录/注册页
NEXT_PUBLIC_SELF_HOST=true

# ========== 认证 API (SELF_HOST=false 时使用, 服务端-only) ==========
AUTH_API_BASE=https://agentinsight.goldebridge.com

# ========== JWT 本地解析 (与后端共享密钥, 前端 middleware.ts 校验 token) ==========
# 密钥仅环境变量注入, 禁止入仓/硬编码
# 注: 前端 Edge Runtime 仅校验 token 签名 (不刷新), 完整用户信息从 /api/auth/me 获取
JWT_SIGNING_KEY=
JWT_ISSUER=
JWT_AUDIENCE=
# JWT_ALGORITHM=HS256  # 固定值, 无需配置
# JWT_CLOCK_SKEW=5  # 默认 5s, 无需配置

# ========== 前端端口 ==========
PORT=3000
