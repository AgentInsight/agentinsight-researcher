# ========== Agent API 地址 (运行时变量, 非 NEXT_PUBLIC_ 前缀, 不被构建时内联) ==========
# 客户端浏览器通过 /api/proxy/* 同源代理访问后端, 无需直连后端端口
# 使用 Docker compose 网络内的服务名 + 端口
AGENT_RESEARCHER_API_URL=http://agent-researcher:8066

# ========== SELF_HOST 模式 (运行时变量, 非 NEXT_PUBLIC_ 前缀, 不被构建时内联) ==========
# true: 跳过登录/注册, 直接进聊天页
# false: 显示登录/注册页
# 由 .env / .env.qa 提供, compose env_file 注入容器
SELF_HOST=true

# ========== 认证 API (SELF_HOST=false 时使用, 服务端-only) ==========
AUTH_API_BASE=https://agentinsight.goldebridge.com

# ========== 前端端口 ==========
PORT=8801